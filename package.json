{
  "name": "one-tech",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "dev:webpack": "next dev --webpack",
    "dev:webpack:poll": "CHOKIDAR_USEPOLLING=1 WATCHPACK_POLLING=true next dev --webpack",
    "dev:clean": "rm -rf .next && next dev",
    "dev:trace": "NEXT_TURBOPACK_TRACING=1 next dev",
    "trace:analyze": "bunx next internal trace .next/dev/trace-turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint src --fix",
    "lint:strict": "eslint --max-warnings=0 src",
    "typecheck": "tsc --noEmit --incremental false",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,json}\"",
    "prettier:format": "prettier --write .",
    "version:sync": "bun run scripts/sync-version.ts",
    "postversion": "bun run version:sync && git add README.md && git commit --amend --no-edit",
    "release": "bun version patch && git push --follow-tags",
    "generate": "bunx plop --plopfile ./.plop/plopfile.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.44",
    "@ai-sdk/react": "^2.0.104",
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "^16.2.4",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^1.5.0",
    "ai": "^5.0.104",
    "axios": "^1.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.24",
    "gsap": "^3.14.2",
    "js-cookie": "^3.0.5",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.11",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.8.16",
    "nprogress": "^0.2.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-countup": "^6.5.3",
    "react-day-picker": "8.10.1",
    "react-dom": "^19.2.6",
    "react-dropzone": "^14.3.8",
    "react-fast-marquee": "^1.6.5",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-paginate": "^8.3.0",
    "react-share": "^5.3.0",
    "react-use": "^17.6.0",
    "sonner": "^2.0.3",
    "swr": "^2.3.3",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.18.0",
    "@next/eslint-plugin-next": "^15.4.5",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.20",
    "@types/msgpack-lite": "^0.1.11",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import-helpers": "^2.0.1",
    "eslint-plugin-prettier": "^5.3.1",
    "eslint-plugin-react": "7.35.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier-plugin-sort-json": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "globals": "^16.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "plop": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
